# ─────────────────────────────────────────────────────────────────────────────
# portfolio-api environment variables
# Copy to `.env` and fill in real values. Validated at startup by Joi
# (src/config/env.validation.ts) — the app fails to boot if a required var is
# missing or invalid. No real secrets belong in this file.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode: development | production | test. Gates Swagger UI (off in production).
NODE_ENV=development

# HTTP port. On Render this is injected automatically — do not hardcode in prod.
PORT=4000

# Direct Postgres connection used by the Prisma datasource (url + directUrl).
DIRECT_URL=postgresql://user:password@host:5432/portfolio?sslmode=require

# Pooled Postgres connection (Neon pooler). Required by validation.
DATABASE_URL=postgresql://user:password@host:5432/portfolio?sslmode=require&pgbouncer=true

# JWT signing secret — MUST be at least 32 characters. Generate a random value.
JWT_SECRET=replace-with-a-long-random-string-min-32-chars

# Access token lifetime (e.g. 15m, 7d). Defaults to 7d if unset.
JWT_EXPIRES_IN=7d

# Cloudinary account cloud name (file storage). Found in the Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key — server-side credential pair for signed uploads/deletes.
CLOUDINARY_API_KEY=your-cloudinary-api-key

# Cloudinary API secret — keep private, never expose to the client.
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Base folder uploads are organized under (per-user subfolders are appended).
# Defaults to portfolio/develop if unset.
CLOUDINARY_FOLDER=portfolio/develop

# Comma-separated list of allowed CORS origins. Defaults to http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# ── Contact form email delivery (Resend) — all optional ──────────────────────
# Without RESEND_API_KEY the contact endpoint returns delivered:false and the
# frontend falls back to a mailto: link.

# Resend API key. Leave empty to disable email delivery.
RESEND_API_KEY=

# From address for outgoing contact emails (e.g. "Portfolio <noreply@yourdomain.com>").
MAIL_FROM=

# Destination address that receives contact form submissions.
CONTACT_TO=

# ── Seed-only (read by prisma/seed.ts, not by the Joi schema) ────────────────
# Used by `npm run seed` to create the single owner user. Not needed at runtime.

# Owner login email.
SEED_EMAIL=owner@example.com

# Owner password (will be bcrypt-hashed by the seed script).
SEED_PASSWORD=change-me

# Owner username. Defaults to "admin" if unset.
SEED_USERNAME=admin
